{
  "name": "@schemat/cli",
  "version": "0.1.0",
  "description": "Git-native database schema documentation \u2014 live interactive ER diagrams from your repo.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "schemat": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts dev --root ../../examples/blog"
  },
  "dependencies": {
    "@schemat/core": "workspace:*",
    "@schemat/parser-dbml": "workspace:*",
    "@schemat/parser-drizzle": "workspace:*",
    "@schemat/parser-mikroorm": "workspace:*",
    "@schemat/parser-mongoose": "workspace:*",
    "@schemat/parser-prisma": "workspace:*",
    "@schemat/parser-sql": "workspace:*",
    "@schemat/parser-typeorm": "workspace:*",
    "@schemat/render": "workspace:*",
    "@schemat/web": "workspace:*",
    "chokidar": "4.0.3",
    "commander": "12.1.0",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/ws": "8.5.13",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "author": "Ali Reza Hamid <alirezahamid1996@gmail.com>",
  "homepage": "https://github.com/alirezahamid/schemat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alirezahamid/schemat.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/alirezahamid/schemat/issues"
  },
  "keywords": [
    "prisma",
    "erd",
    "schema",
    "database",
    "er-diagram",
    "git-native",
    "documentation",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
